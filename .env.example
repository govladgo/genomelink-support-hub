# Genomelink Support hub — no env vars required to run.
#
# For tools that LINK INTO this hub (genomelink-one-on-one, genomelink-match-hub,
# genomelink-cm-predictor, dna-painter-v2, network-graph-prototype-2-0), set:
#
#   NEXT_PUBLIC_SUPPORT_HUB_URL=http://localhost:3013   # dev
#   NEXT_PUBLIC_SUPPORT_HUB_URL=https://genomelink-support-hub.vercel.app   # prod
#
# in those repos' env files.
